{
  "name": "modern-barcode-scanner",
  "version": "1.0.2",
  "description": "A high-performance barcode scanner React component with optimized detection, torch control, and camera switching",
  "author": "Sumit Sahoo",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/modern-barcode-scanner.css"
  },
  "files": [
    "dist",
    "!dist/assets",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sumitsahoo/modern-barcode-scanner.git"
  },
  "bugs": {
    "url": "https://github.com/sumitsahoo/modern-barcode-scanner/issues"
  },
  "homepage": "https://github.com/sumitsahoo/modern-barcode-scanner#readme",
  "keywords": [
    "barcode",
    "scanner",
    "qr-code",
    "react",
    "zbar",
    "camera",
    "web-worker",
    "pwa"
  ],
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p demo/tsconfig.json",
    "preview": "vite preview --config demo/vite.config.ts",
    "prepublishOnly": "npm run build",
    "format": "npx biome format ./ --write",
    "lint": "npx biome lint ./",
    "lint:fix": "npx biome lint ./ --write",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@undecaf/zbar-wasm": "^0.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
