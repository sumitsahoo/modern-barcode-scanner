{
  "name": "modern-barcode-scanner",
  "version": "1.0.3",
  "description": "A high-performance barcode scanner React component with optimized detection, torch control, and camera switching",
  "keywords": [
    "barcode",
    "camera",
    "pwa",
    "qr-code",
    "react",
    "scanner",
    "web-worker",
    "zbar"
  ],
  "homepage": "https://github.com/sumitsahoo/modern-barcode-scanner#readme",
  "bugs": {
    "url": "https://github.com/sumitsahoo/modern-barcode-scanner/issues"
  },
  "license": "MIT",
  "author": "Sumit Sahoo",
  "repository": {
    "type": "git",
    "url": "https://github.com/sumitsahoo/modern-barcode-scanner.git"
  },
  "files": [
    "dist",
    "!dist/assets",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/modern-barcode-scanner.css"
  },
  "scripts": {
    "dev": "vp dev --config demo/vite.config.ts",
    "build": "vp build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p demo/tsconfig.json",
    "preview": "vp preview --config demo/vite.config.ts",
    "prepublishOnly": "npm run build",
    "format": "vp fmt --write",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "check": "vp check && npm run typecheck",
    "test": "vp test run"
  },
  "dependencies": {
    "@undecaf/zbar-wasm": "^0.11.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.17.0",
      "onFail": "download"
    }
  }
}
